// Prisma schema for FitBook – Personal Trainer Management & Booking App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  TRAINER
  CLIENT
}

enum WorkoutType {
  STRENGTH
  CARDIO
  MOBILITY
  HIIT
  OTHER
}

enum SessionStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum PackageType {
  SESSION_COUNT // fixed number of sessions
  WEEKLY        // ongoing, sessions per week
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── App models ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  role               Role    @default(CLIENT)
  onboardingComplete Boolean @default(false)
  emailReminders     Boolean @default(true)

  googleAccessToken  String? @db.Text
  googleRefreshToken String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Booking relations
  sessionsAsTrainer BookingSession[] @relation("TrainerSessions")
  sessionsAsClient  BookingSession[] @relation("ClientSessions")
  availability      Availability[]

  // Trainer–client management
  trainerClients TrainerClient[] @relation("TrainerClients")
  clientTrainers TrainerClient[] @relation("ClientTrainers")
}

// Named BookingSession to avoid conflict with NextAuth Session model
model BookingSession {
  id           String        @id @default(cuid())
  trainerId    String
  clientId     String
  startTime    DateTime
  endTime      DateTime
  workoutType  WorkoutType
  notes        String?       @db.Text
  trainerNotes String?       @db.Text
  status       SessionStatus @default(UPCOMING)
  googleEventId String?
  reminderSent  Boolean      @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  trainer      User          @relation("TrainerSessions", fields: [trainerId], references: [id])
  client       User          @relation("ClientSessions", fields: [clientId], references: [id])
  exerciseLogs ExerciseLog[]
}

model Availability {
  id        String @id @default(cuid())
  trainerId String
  dayOfWeek Int
  startTime String
  endTime   String

  trainer User @relation(fields: [trainerId], references: [id], onDelete: Cascade)
}

// ─── Client Management ────────────────────────────────────────────────────────

/// One record per trainer–client pair. Holds package & grace period config.
model TrainerClient {
  id               String      @id @default(cuid())
  trainerId        String
  clientId         String
  packageType      PackageType @default(SESSION_COUNT)
  totalSessions    Int?        // SESSION_COUNT: total sessions purchased
  sessionsPerWeek  Int?        // WEEKLY: target sessions per week
  sessionsUsed     Int         @default(0)
  gracePeriodWeeks Int         @default(3)
  packageStartDate DateTime    @default(now())
  internalNotes    String?     @db.Text // trainer-only notes about this client
  active           Boolean     @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trainer      User          @relation("TrainerClients", fields: [trainerId], references: [id])
  client       User          @relation("ClientTrainers", fields: [clientId], references: [id])
  workoutPlans WorkoutPlan[]

  @@unique([trainerId, clientId])
}

/// A named workout plan assigned to a client by their trainer.
model WorkoutPlan {
  id              String        @id @default(cuid())
  trainerClientId String
  name            String
  description     String?       @db.Text
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  trainerClient TrainerClient  @relation(fields: [trainerClientId], references: [id], onDelete: Cascade)
  exercises     PlanExercise[]
}

/// An exercise within a workout plan, with trainer-set targets.
model PlanExercise {
  id           String  @id @default(cuid())
  planId       String
  name         String
  targetSets   Int     @default(3)
  targetReps   String  @default("10") // e.g. "8-12" or "10"
  targetWeight Float?  // kg, optional
  order        Int     @default(0)

  plan WorkoutPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  logs ExerciseLog[]
}

/// Actual performance log for one exercise in one session.
model ExerciseLog {
  id            String   @id @default(cuid())
  sessionId     String
  exerciseId    String
  setsLogged    Int
  repsLogged    String   // per-set reps, comma-separated e.g. "10,10,8"
  weightUsed    Float?   // kg (kept for backward compat / single weight)
  weightsLogged String?  // per-set weights, comma-separated e.g. "70,70,75"
  notes         String?  @db.Text
  createdAt     DateTime @default(now())

  session  BookingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise PlanExercise   @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}
